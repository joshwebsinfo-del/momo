# ============================================================
# Love Journey — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ----- Django Core -----
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ----- Supabase PostgreSQL -----
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your-supabase-db-password
SUPABASE_DB_HOST=db.xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_DB_PORT=5432

# ----- Supabase Storage -----
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ----- Couple Access Control -----
# Only these two emails may register
ALLOWED_EMAIL_1=partner1@example.com
ALLOWED_EMAIL_2=partner2@example.com

# ----- Relationship -----
# Used as fallback if SiteSettings DB record not yet created
RELATIONSHIP_START_DATE=2023-01-01

# ----- Redis (Celery) -----
REDIS_URL=redis://localhost:6379/0

# ----- Email (password reset) -----
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# ----- Security (production only) -----
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
